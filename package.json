{
  "name": "schemacraft-validator",
  "version": "1.0.0",
  "description": "Schema.org structured data validator — accuracy-matched to validator.schema.org. Supports JSON-LD, Microdata, and RDFa.",
  "author": "Abdo Elbradey",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "schemacraft-validator": "bin/schemacraft-validator.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:accuracy": "vitest run tests/accuracy/",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "update-vocab": "tsx scripts/update-vocab.ts",
    "accuracy-report": "tsx scripts/accuracy-report.ts",
    "build-fixtures": "tsx scripts/build-accuracy-fixtures.ts",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "schema.org",
    "structured-data",
    "json-ld",
    "microdata",
    "rdfa",
    "validator",
    "seo",
    "rich-results",
    "schema-markup",
    "sdtt"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Elbradey8/schemacraft-validator"
  },
  "homepage": "https://schemacraft.net/validator",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0",
    "commander": "^12.0.0",
    "express": "^4.21.0",
    "jsonld": "^8.3.0",
    "microdata-node": "^2.0.0",
    "n3": "^1.17.0",
    "rdfa-streaming-parser": "^3.0.0",
    "undici": "^6.0.0"
  },
  "peerDependencies": {
    "puppeteer": ">=20.0.0"
  },
  "peerDependenciesMeta": {
    "puppeteer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/n3": "^1.16.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
